#!/bin/bash
# Run all quality gates

echo "Running all quality gates..."
echo ""

FAILED=0

echo "=== Gate 1: Documentation ==="
bash scripts/check-docs
if [ $? -ne 0 ]; then
    FAILED=$((FAILED + 1))
fi
echo ""

echo "=== Gate 2: Boundaries ==="
bash scripts/check-boundaries
if [ $? -ne 0 ]; then
    FAILED=$((FAILED + 1))
fi
echo ""

echo "=== Gate 3: Forbidden Dependencies ==="
bash scripts/check-forbidden-deps
if [ $? -ne 0 ]; then
    FAILED=$((FAILED + 1))
fi
echo ""

echo "=== Gate 4: Contract Mirror ==="
bash scripts/check-contract-mirror
if [ $? -ne 0 ]; then
    FAILED=$((FAILED + 1))
fi
echo ""

if [ $FAILED -eq 0 ]; then
    echo "✓ All quality gates passed"
    exit 0
else
    echo "✗ $FAILED quality gate(s) failed"
    exit 1
fi
