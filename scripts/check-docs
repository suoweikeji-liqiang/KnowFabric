#!/usr/bin/env bash
# Quality Gate: Documentation Completeness Check

set -e
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

echo "=== Documentation Completeness Check ==="
FAILED=0

# Check core docs
CORE_DOCS=("docs/00_repo-charter.md" "docs/01_system-boundaries.md" "docs/02_data-layer-contract.md" "docs/03_domain-package-spec.md" "docs/04_engineering-standards.md" "docs/05_phase-plan.md" "docs/06_quality-gates.md")
for doc in "${CORE_DOCS[@]}"; do
  [ ! -f "$doc" ] && echo "❌ Missing: $doc" && FAILED=1
done

# Check package READMEs
for pkg in packages/*/; do
  [ -d "$pkg" ] && [ ! -f "${pkg}README.md" ] && echo "❌ Missing: ${pkg}README.md" && FAILED=1
done

# Check domain packages
for domain in domain_packages/*/; do
  if [ -d "$domain" ]; then
    [ ! -f "${domain}manifest.yaml" ] && echo "❌ Missing: ${domain}manifest.yaml" && FAILED=1
    [ ! -f "${domain}label_schema.yaml" ] && echo "❌ Missing: ${domain}label_schema.yaml" && FAILED=1
    [ ! -f "${domain}entity_schema.yaml" ] && echo "❌ Missing: ${domain}entity_schema.yaml" && FAILED=1
  fi
done

[ $FAILED -eq 0 ] && echo "✅ Documentation check PASSED" && exit 0
echo "❌ Documentation check FAILED" && exit 1
