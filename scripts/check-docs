#!/bin/bash
# Check documentation completeness

echo "Checking documentation completeness..."

ERRORS=0

# Check core docs
CORE_DOCS=(
    "docs/00_repo-charter.md"
    "docs/01_system-boundaries.md"
    "docs/02_data-layer-contract.md"
    "docs/03_domain-package-spec.md"
    "docs/04_engineering-standards.md"
    "docs/05_phase-plan.md"
    "docs/06_quality-gates.md"
    "docs/07_phase1-implementation-contract.md"
)

for doc in "${CORE_DOCS[@]}"; do
    if [ ! -f "$doc" ]; then
        echo "✗ Missing: $doc"
        ERRORS=$((ERRORS + 1))
    fi
done

# Check package READMEs
PACKAGES=(
    "packages/core"
    "packages/db"
    "packages/storage"
    "packages/ingest"
    "packages/parser"
    "packages/chunking"
    "packages/retrieval"
)

for pkg in "${PACKAGES[@]}"; do
    if [ ! -f "$pkg/README.md" ]; then
        echo "✗ Missing: $pkg/README.md"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ $ERRORS -eq 0 ]; then
    echo "✓ All documentation present"
    exit 0
else
    echo "✗ Found $ERRORS missing documentation files"
    exit 1
fi
