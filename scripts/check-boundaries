#!/bin/bash
# Check module boundaries

echo "Checking module boundaries..."

ERRORS=0

# Check that core doesn't import from other packages
if grep -r "from packages\." packages/core/*.py 2>/dev/null | grep -v "from packages.core"; then
    echo "✗ Core package imports from other packages"
    ERRORS=$((ERRORS + 1))
fi

if [ $ERRORS -eq 0 ]; then
    echo "✓ Module boundaries respected"
    exit 0
else
    echo "✗ Found $ERRORS boundary violations"
    exit 1
fi
