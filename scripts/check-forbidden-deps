#!/bin/bash
# Check forbidden dependencies

echo "Checking forbidden dependencies..."

ERRORS=0

# Check domain packages don't contain SQL
if grep -r "SELECT\|INSERT\|UPDATE\|DELETE" domain_packages/ 2>/dev/null; then
    echo "✗ Domain packages contain SQL"
    ERRORS=$((ERRORS + 1))
fi

if [ $ERRORS -eq 0 ]; then
    echo "✓ No forbidden dependencies found"
    exit 0
else
    echo "✗ Found $ERRORS forbidden dependencies"
    exit 1
fi
