{
  "backends": [
    {
      "name": "deepseek-remote",
      "api_base_url": "https://your-openai-compatible-endpoint.example/v1",
      "model": "deepseek-chat",
      "api_key_env": "DEEPSEEK_API_KEY",
      "timeout_seconds": 45
    },
    {
      "name": "mlx-local",
      "api_base_url": "http://127.0.0.1:8080/v1",
      "model": "mlx-community-model",
      "api_key_env": "MLX_API_KEY",
      "timeout_seconds": 30
    }
  ]
}
