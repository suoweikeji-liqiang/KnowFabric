      "api_base_url_env": "DEEPSEEK_API_BASE_URL",
      "model": "deepseek-chat",
      "api_key_env": "DEEPSEEK_API_KEY",
      "timeout_seconds": 45
    },
    {
      "name": "deepseek-v4-pro-judge",
