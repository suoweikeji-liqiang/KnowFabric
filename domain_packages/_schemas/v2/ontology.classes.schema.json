{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowfabric.dev/schemas/domain-package-v2/ontology.classes.schema.json",
  "title": "KnowFabric Domain Package V2 Ontology Classes",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "classes"
  ],
  "properties": {
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          },
          "parent_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "equipment",
              "component",
              "concept"
            ]
          },
          "external_mappings": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          },
          "aliases": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "knowledge_anchors": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          }
        }
      }
    }
  },
  "$comment": "Cross-record uniqueness and parent existence are enforced by packages/domain_kit_v2."
}
